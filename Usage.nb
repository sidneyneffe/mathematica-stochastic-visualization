  3.989655509499909*^9}},ExpressionUUID->"a70d73d0-63ab-4a97-af13-\
ee64b43abd9e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"distributionToString", "[", "distribution_", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "newName", "}"}], ",", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"newName", "=", 
       RowBox[{
        RowBox[{"Head", "[", "distribution", "]"}], "/.", " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"NormalDistribution", "->", "\"\<\[ScriptCapitalN]\>\""}], 
          ",", 
          RowBox[{"GammaDistribution", "->", "\"\<\[CapitalGamma]\>\""}], ",", 
          RowBox[{"ExponentialDistribution", "->", "\"\<Exp\>\""}], ",", 
          RowBox[{"BetaDistribution", "->", "\"\<\[Beta]\>\""}], ",", 
          RowBox[{"BinomialDistribution", "->", "\"\<Bin\>\""}], ",", 
          RowBox[{"GeometricDistribution", "->", "\"\<Geo\>\""}], ",", 
          RowBox[{"PoissonDistribution", "->", "\"\<Poisson\>\""}], ",", 
          RowBox[{
          "ChiSquareDistribution", "->", 
           "\"\<\\!\\(\\*SuperscriptBox[\\(\[Chi]\\), \\(2\\)]\\)\>\""}], ",", 
          RowBox[{"CauchyDistribution", "->", "\"\<Cauchy\>\""}], ",", 
          RowBox[{"StudentTDistribution", "->", "\"\<t\>\""}], ",", 
          RowBox[{"UniformDistribution", "->", "\"\<\[ScriptCapitalU]\>\""}], 
          ",", 
          RowBox[{
          "TriangularDistribution", "->", "\"\<\[CapitalDelta]\>\""}]}], 
         "}"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"newName", "===", 
          RowBox[{"Head", "[", "distribution", "]"}]}], ",", 
         RowBox[{"ToString", "[", 
          RowBox[{"Head", "@", "distribution"}], "]"}], ",", "newName"}], 
        "]"}], "<>", "\"\<(\>\"", "<>", 
       RowBox[{"StringRiffle", "[", 
        RowBox[{
         RowBox[{"ToString", "/@", 
          RowBox[{"Level", "[", 
           RowBox[{"distribution", ",", "1"}], "]"}]}], ",", "\"\<,\>\""}], 
        "]"}], "<>", "\"\<)\>\""}]}], ")"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.989661645685625*^9, 3.9896616456893263`*^9}},
 CellLabel->"In[4]:=",ExpressionUUID->"a81d4fda-16b9-450a-9de4-a501e04e2630"],

Cell[BoxData[
 RowBox[{"Quit", "[", "]"}]], "Input",
