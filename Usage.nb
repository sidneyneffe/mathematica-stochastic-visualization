Cell[BoxData[{
 RowBox[{
  RowBox[{"gDistribution", "=", 
   RowBox[{"TransformedDistribution", "[", 
    RowBox[{
     RowBox[{"1", "+", "X"}], ",", 
     RowBox[{"X", "\[Distributed]", 
      RowBox[{"ExponentialDistribution", "[", "1", "]"}]}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"SVRejectionPlot", "[", 
  RowBox[{
   RowBox[{"Piecewise", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{
          RowBox[{"-", 
           SuperscriptBox["x", "2"]}], "/", "2"}]], ",", " ", 
        RowBox[{"1", "<=", "x"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"0", ",", " ", "True"}], "}"}]}], "}"}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "0", ",", "5"}], "}"}], ",", "gDistribution", ",", 
   FractionBox["1", 
    SqrtBox["\[ExponentialE]"]], ",", 
   RowBox[{"NSamples", "->", "700"}]}], "]"}]}], "Input",
